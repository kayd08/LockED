<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LockED - Digital Security Initiative</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', sans-serif;
        }
        
        :root {
            --primary: #6366f1;
            --primary-dark: #4f46e5;
            --secondary: #ec4899;
            --accent: #8b5cf6;
            --dark: #0f172a;
            --darker: #020617;
            --light: #f8fafc;
            --gray: #64748b;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --locked-red: #dc2626;
            --locked-cyan: #06b6d4;
        }
        
        html, body {
            background: var(--darker);
            color: var(--light);
            overflow-x: hidden;
            scroll-behavior: smooth;
        }
        
        /* Toggle Button - Fixed Position */
        .nav-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 1001;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            border: none;
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .nav-toggle:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        }
        
        /* Navigation - Completely Hidden Off-Screen */
        .navigation {
            position: fixed;
            top: 50%;
            right: -300px; /* Start completely off-screen to the right */
            transform: translateY(-50%);
            width: 250px;
            height: 500px;
            background: rgba(15, 23, 42, 0.98);
            backdrop-filter: blur(10px);
            border-radius: 20px 0 0 20px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-right: none;
            box-shadow: -5px 0 30px rgba(0, 0, 0, 0.5);
            transition: right 0.4s ease;
            overflow: hidden;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 20px;
        }
        
        .navigation.show {
            right: 0; /* Slide in from right when shown */
        }
        
        .navigation ul {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding-top: 20px;
            list-style: none;
        }
        
        .navigation ul li {
            position: relative;
            width: 100%;
            margin-bottom: 5px;
        }
        
        .navigation ul li.active {
            background: linear-gradient(90deg, transparent, rgba(6, 182, 212, 0.3));
            border-left: 4px solid var(--locked-cyan);
        }
        
        .navigation ul li a {
            display: flex;
            align-items: center;
            text-decoration: none;
            color: var(--light);
            padding: 15px 20px;
            transition: 0.3s;
        }
        
        .navigation ul li:hover a,
        .navigation ul li.active a {
            color: var(--locked-cyan);
        }
        
        .navigation ul li a .icon {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            margin-right: 15px;
        }
        
        .navigation ul li a .title {
            font-size: 1rem;
            white-space: nowrap;
        }
        
        /* Main Content - Full Width Always */
        .main-content {
            width: 100%;
            min-height: 100vh;
        }
        
        /* Logo Styles */
        .logo-container {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            margin-bottom: 30px;
        }
        
        .logo-svg {
            width: 100px;
            height: 100px;
            margin-bottom: 15px;
            filter: drop-shadow(0 0 20px rgba(6, 182, 212, 0.3));
        }
        
        .brand-name {
            font-size: 3.5rem;
            font-weight: 800;
            letter-spacing: 4px;
            background: linear-gradient(135deg, #fff 0%, #94a3b8 50%, #fff 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-transform: uppercase;
        }
        
        .brand-name span {
            background: linear-gradient(135deg, var(--locked-red), #f87171);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .tagline {
            font-size: 1rem;
            color: var(--gray);
            letter-spacing: 6px;
            text-transform: uppercase;
            margin-top: 8px;
        }
        
        @media (max-width: 768px) {
            .brand-name {
                font-size: 2.5rem;
                letter-spacing: 2px;
            }
            .tagline {
                font-size: 0.8rem;
                letter-spacing: 3px;
            }
            .logo-svg {
                width: 80px;
                height: 80px;
            }
        }
        
        /* Home Page - Scrollable Layout */
        .home-section {
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            padding: 80px 20px 40px;
        }
        
        .home-header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        /* Slider Container */
        .slider-wrapper {
            width: 100%;
            max-width: 1100px;
            margin-bottom: 60px;
        }
        
        .slider-container {
            width: 100%;
            height: 450px;
            position: relative;
            overflow: hidden;
            border-radius: 20px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }
        
        @media (max-width: 768px) {
            .slider-container {
                height: 380px;
            }
        }
        
        .slide {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 0;
            transition: 0.8s ease-in-out;
            display: flex;
            align-items: center;
            padding: 0 8%;
        }
        
        .slide.active {
            opacity: 1;
        }
        
        .slide-content {
            max-width: 450px;
            z-index: 2;
        }
        
        .slide-content h1 {
            font-size: 3rem;
            font-weight: 800;
            margin-bottom: 1rem;
            text-transform: uppercase;
            line-height: 1.1;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
        }
        
        @media (max-width: 768px) {
            .slide-content h1 {
                font-size: 2rem;
            }
        }
        
        .slide-content p {
            font-size: 1rem;
            margin-bottom: 1.5rem;
            opacity: 0.9;
            line-height: 1.6;
        }
        
        .slide-btn {
            display: inline-block;
            padding: 12px 30px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255,255,255,0.3);
            color: white;
            text-decoration: none;
            border-radius: 30px;
            font-weight: 600;
            transition: all 0.3s;
            cursor: pointer;
        }
        
        .slide-btn:hover {
            background: white;
            color: var(--dark);
            transform: translateY(-3px);
        }
        
        .slide-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
        }
        
        .slider-controls {
            position: absolute;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 12px;
            z-index: 10;
        }
        
        .slider-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            cursor: pointer;
            transition: 0.3s;
        }
        
        .slider-dot.active {
            background: white;
            transform: scale(1.3);
        }
        
        .slider-arrows {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 60px;
            z-index: 10;
        }
        
        .arrow {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: 0.3s;
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .arrow:hover {
            background: rgba(255,255,255,0.3);
        }
        
        /* Slide backgrounds */
        .slide:nth-child(1) { background: linear-gradient(135deg, #1e1b4b 0%, #4338ca 100%); }
        .slide:nth-child(2) { background: linear-gradient(135deg, #7f1d1d 0%, #dc2626 100%); }
        .slide:nth-child(3) { background: linear-gradient(135deg, #064e3b 0%, #059669 100%); }
        .slide:nth-child(4) { background: linear-gradient(135deg, #0c4a6e 0%, #0284c7 100%); }
        .slide:nth-child(5) { background: linear-gradient(135deg, #701a75 0%, #c026d3 100%); }
        .slide:nth-child(6) { background: linear-gradient(135deg, #1e293b 0%, #475569 100%); }
        
        /* Scroll Down Indicator */
        .scroll-indicator {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin: 30px 0;
            color: var(--gray);
            animation: bounce 2s infinite;
            cursor: pointer;
            text-decoration: none;
        }
        
        .scroll-indicator span {
            font-size: 0.9rem;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }
        
        .scroll-indicator i {
            font-size: 1.5rem;
        }
        
        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-10px); }
            60% { transform: translateY(-5px); }
        }
        
        /* About Preview Section - Below the fold */
        .about-preview {
            min-height: 100vh;
            width: 100%;
            max-width: 1200px;
            padding: 60px 20px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }
        
        .about-preview h2 {
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 40px;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .about-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }
        
        .about-card {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }
        
        .about-card:hover {
            transform: translateY(-5px);
            border-color: rgba(6, 182, 212, 0.3);
        }
        
        .about-card i {
            font-size: 2.5rem;
            color: var(--locked-cyan);
            margin-bottom: 20px;
        }
        
        .about-card h3 {
            font-size: 1.3rem;
            margin-bottom: 15px;
        }
        
        .about-card p {
            color: var(--gray);
            line-height: 1.6;
        }
        
        .view-full-about {
            text-align: center;
            margin-top: 40px;
        }
        
        .view-full-about button {
            padding: 15px 40px;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            border: none;
            border-radius: 30px;
            color: white;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
        }
        
        .view-full-about button:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(6, 182, 212, 0.3);
        }
        
        /* Section Styles */
        .section {
            display: none;
            min-height: 100vh;
            padding: 80px 20px 40px;
            animation: fadeIn 0.5s ease-in;
        }
        
        .section.active {
            display: block;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .section-header {
            text-align: center;
            margin-bottom: 40px;
        }
        
        .section-header h2 {
            font-size: 2.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }
        
        .section-header p {
            color: var(--gray);
        }
        
        /* Table of Contents */
        .toc {
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            padding: 25px;
            margin-bottom: 30px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .toc h3 {
            margin-bottom: 15px;
            color: var(--locked-cyan);
            font-size: 1.3rem;
        }
        
        .toc ul {
            list-style: none;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 10px;
        }
        
        .toc li a {
            color: var(--gray);
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px;
            border-radius: 8px;
            transition: 0.3s;
            font-size: 0.95rem;
        }
        
        .toc li a:hover {
            background: rgba(6, 182, 212, 0.1);
            color: var(--locked-cyan);
        }
        
        /* Back to Top Button */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            border: none;
            color: white;
            font-size: 1.1rem;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
            transition: all 0.3s;
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .back-to-top.show {
            opacity: 1;
            visibility: visible;
        }
        
        .back-to-top:hover {
            transform: translateY(-5px);
        }
        
        /* Content Cards */
        .content-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
            margin-bottom: 30px;
        }
        
        .content-card {
            background: rgba(255,255,255,0.05);
            border-radius: 15px;
            padding: 25px;
            border: 1px solid rgba(255,255,255,0.1);
            transition: 0.3s;
        }
        
        .content-card:hover {
            transform: translateY(-5px);
            border-color: rgba(6, 182, 212, 0.3);
        }
        
        .content-card h3 {
            font-size: 1.3rem;
            margin-bottom: 15px;
        }
        
        .content-card .icon-box {
            width: 50px;
            height: 50px;
            border-radius: 12px;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
            font-size: 1.3rem;
        }
        
        .content-card ul {
            list-style: none;
        }
        
        .content-card ul li {
            padding: 6px 0;
            font-size: 0.95rem;
            display: flex;
            align-items: start;
            gap: 8px;
        }
        
        .content-card ul li i {
            color: var(--success);
            margin-top: 3px;
            font-size: 0.9rem;
        }
        
        .content-card ul li i.fa-times {
            color: var(--danger);
        }
        
        /* Stats */
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 15px;
            margin: 30px 0;
        }
        
        .stat-box {
            background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(220, 38, 38, 0.1));
            border-radius: 12px;
            padding: 20px;
            text-align: center;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .stat-box h4 {
            font-size: 2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--locked-cyan), var(--locked-red));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .stat-box p {
            color: var(--gray);
            font-size: 0.85rem;
            margin-top: 5px;
        }
        
        /* Do's and Don'ts */
        .dos-donts {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            margin: 25px 0;
        }
        
        @media (max-width: 768px) {
            .dos-donts {
                grid-template-columns: 1fr;
            }
        }
        
        .do-box, .dont-box {
            border-radius: 15px;
            padding: 25px;
        }
        
        .do-box {
            background: linear-gradient(135deg, rgba(16, 185, 129, 0.1), rgba(16, 185, 129, 0.05));
            border: 2px solid rgba(16, 185, 129, 0.3);
        }
        
        .dont-box {
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(239, 68, 68, 0.05));
            border: 2px solid rgba(239, 68, 68, 0.3);
        }
        
        .do-box h3, .dont-box h3 {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 15px;
            font-size: 1.2rem;
        }
        
        .do-box h3 { color: var(--success); }
        .dont-box h3 { color: var(--danger); }
        
        /* Digital Inclusion Content */
        .digital-inclusion-content {
            max-width: 900px;
            margin: 0 auto;
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 30px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .digital-inclusion-content h1 {
            font-size: 2.5rem;
            text-align: center;
            margin-bottom: 10px;
            background: linear-gradient(135deg, #ec4899, #8b5cf6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .digital-inclusion-content .subtitle {
            text-align: center;
            font-size: 1.2rem;
            color: var(--gray);
            margin-bottom: 30px;
        }
        
        .advocacy-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin: 25px 0;
        }
        
        @media (max-width: 768px) {
            .advocacy-grid { grid-template-columns: 1fr; }
        }
        
        .advocacy-card {
            text-align: center;
            padding: 15px;
        }
        
        .advocacy-card img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            border-radius: 10px;
            margin-bottom: 10px;
        }
        
        .info-section {
            margin: 30px 0;
            padding: 25px;
            background: rgba(255,255,255,0.03);
            border-radius: 15px;
        }
        
        .info-section h3 {
            color: #ec4899;
            font-size: 1.5rem;
            margin-bottom: 15px;
        }
        
        .two-col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            align-items: center;
        }
        
        @media (max-width: 768px) {
            .two-col { grid-template-columns: 1fr; }
        }
        
        .two-col img {
            width: 100%;
            border-radius: 10px;
        }
        
        .causes-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 15px;
            margin: 25px 0;
        }
        
        @media (max-width: 768px) {
            .causes-grid { grid-template-columns: 1fr; }
        }
        
        .cause-card {
            text-align: center;
            padding: 15px;
            background: rgba(255,255,255,0.05);
            border-radius: 12px;
        }
        
        .cause-card img {
            width: 100%;
            height: 100px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 10px;
        }
        
        .women-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
            margin: 25px 0;
        }
        
        @media (max-width: 768px) {
            .women-grid { grid-template-columns: 1fr; }
        }
        
        .woman-card {
            display: flex;
            gap: 15px;
            background: rgba(255,255,255,0.05);
            padding: 15px;
            border-radius: 12px;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        @media (max-width: 768px) {
            .woman-card { flex-direction: column; }
        }
        
        .woman-card img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 8px;
            flex-shrink: 0;
        }
        
        .woman-info h4 {
            color: #ec4899;
            font-size: 1.1rem;
            margin-bottom: 5px;
        }
        
        .woman-info p {
            font-size: 0.85rem;
            color: var(--gray);
            line-height: 1.5;
        }
        
        /* Mental Health */
        .mental-health-connections {
            background: linear-gradient(135deg, rgba(6, 182, 212, 0.1), rgba(220, 38, 38, 0.1));
            border-radius: 20px;
            padding: 30px;
            margin: 25px 0;
            border: 1px solid rgba(255,255,255,0.1);
        }
        
        .connection-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 25px;
        }
        
        .connection-card {
            background: rgba(0,0,0,0.2);
            padding: 20px;
            border-radius: 12px;
            border-left: 4px solid var(--locked-cyan);
        }
        
        .connection-card h4 {
            color: var(--locked-cyan);
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 1rem;
        }
        
        /* Warning boxes */
        .warning-box {
            background: linear-gradient(135deg, rgba(245, 158, 11, 0.1), rgba(245, 158, 11, 0.05));
            border: 2px solid var(--warning);
            border-radius: 12px;
            padding: 20px;
            margin: 25px 0;
            display: flex;
            align-items: start;
            gap: 15px;
        }
        
        .warning-box i {
            font-size: 1.5rem;
