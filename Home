    <script>
        // Navigation toggle
        function toggleNav() {
            const nav = document.getElementById('navigation');
            nav.classList.toggle('show');
        }
        
        // Close nav when clicking outside
        document.addEventListener('click', (e) => {
            const nav = document.getElementById('navigation');
            const toggle = document.querySelector('.nav-toggle');
            
            if (!nav.contains(e.target) && !toggle.contains(e.target)) {
                nav.classList.remove('show');
            }
        });
        
        // Change section
        function changeSection(sectionId, navItem) {
            document.querySelectorAll('.section').forEach(section => {
                section.classList.remove('active');
            });
            
            document.getElementById(sectionId).classList.add('active');
            
            document.querySelectorAll('.list').forEach(item => {
                item.classList.remove('active');
            });
            
            if (navItem) navItem.classList.add('active');
            
            document.getElementById('navigation').classList.remove('show');
            window.scrollTo(0, 0);
            
            // Show back to top only on learn page
            const backToTop = document.getElementById('backToTop');
            if (sectionId === 'learn') {
                backToTop.classList.add('show');
            } else {
                backToTop.classList.remove('show');
            }
        }
        
        // Scroll to about preview on home page
        function scrollToAbout(e) {
            e.preventDefault();
            document.getElementById('about-preview').scrollIntoView({ behavior: 'smooth' });
        }
        
        // Scroll to section in learn page
        function scrollToSection(id) {
            document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
        }
        
        // Back to top
        function scrollToTop() {
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }
        
        // Show/hide back to top on scroll
        window.addEventListener('scroll', () => {
            const backToTop = document.getElementById('backToTop');
            const learnSection = document.getElementById('learn');
            
            if (learnSection.classList.contains('active') && window.pageYOffset > 300) {
                backToTop.classList.add('show');
            } else if (learnSection.classList.contains('active')) {
                backToTop.classList.remove('show');
            }
        });
        
        // Slider
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const dots = document.querySelectorAll('.slider-dot');
        
        function updateSlider() {
            slides.forEach((slide, index) => {
                slide.classList.remove('active');
                dots[index].classList.remove('active');
            });
            slides[currentSlide].classList.add('active');
            dots[currentSlide].classList.add('active');
        }
        
        function nextSlide() {
            currentSlide = (currentSlide + 1) % slides.length;
            updateSlider();
        }
        
        function prevSlide() {
            currentSlide = (currentSlide - 1 + slides.length) % slides.length;
            updateSlider();
        }
        
        function goToSlide(index) {
            currentSlide = index;
            updateSlider();
        }
        
        setInterval(nextSlide, 5000);
    </script>
